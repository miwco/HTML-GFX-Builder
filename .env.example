# Copy this file to .env (which is gitignored) and fill in what you use.
# Everything can also be set in the app: New project → Describe it → AI settings.

# Your Anthropic API key (https://console.anthropic.com) — used directly from your
# browser, sent only to Anthropic. Never commit a real key.
VITE_ANTHROPIC_API_KEY=

# Model for generation (default: claude-sonnet-5).
VITE_AI_MODEL=

# Hosted mode: a backend gateway URL that holds the real key server-side.
# When set, the app POSTs to $VITE_AI_PROXY_URL/messages and sends no key of its own.
VITE_AI_PROXY_URL=

# ── Supabase backend (Era 5) — all OPTIONAL. Leave blank to run in pure offline mode ──
# (no login, no cloud sync, exports unchanged — exactly the self-hostable offline tool).
# The anon key is PUBLIC (Row Level Security is the real boundary) so it is safe to ship in the
# client bundle. NEVER put the service_role key here or in any VITE_-prefixed var — those are
# bundled into the browser. Server secrets belong in the private deployment's secret store.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Note: there is no "require auth" switch. With a backend configured, the editor is still open to
# everyone — signing in only unlocks the account features (cloud sync, community, AI).

# ── Configured-mode E2E (npm run test:e2e:live) — OPTIONAL, maintainer-only ──────────────────────
# A THROWAWAY test account (email/password, allowlisted) used to exercise the authenticated community
# flows against the configured Supabase backend above. Leave blank and the live suite skips. These are
# NOT VITE_-prefixed, so they are never bundled into the client — point them at a test account on a
# test/staging project, never a production tenant with real users (the specs publish + delete rows).
E2E_EMAIL=
E2E_PASSWORD=
# Optional: the service_role key (server secret — NEVER a VITE_ var) enables the moderator spec, which
# needs to grant/revoke the test account's moderator role. Without it that spec skips.
SUPABASE_SERVICE_ROLE_KEY=

# ── Video/image rendering (Era 7) — all OPTIONAL; leave blank and the feature does not exist ────
# Client flag: shows the Export tab's "Video & image" section. Set on hosted deployments
# (and locally for the offline dev loop — rendering then runs on THIS machine).
VITE_RENDER_API=

# Server-only (Vercel project env / local .env for the dev-server api middleware — NEVER VITE_):
# 'sandbox' on Vercel (renders in Vercel Sandbox); unset/anything else = local child process.
RENDER_EXECUTOR=
# From the Vercel Blob store (Storage → Blob → connect). Holds finished renders until TTL.
BLOB_READ_WRITE_TOKEN=
# Bearer expected by the /api/render/cleanup cron (Vercel sends it automatically when set).
CRON_SECRET=
# Salts anonymous per-IP render quotas. Any long random string.
IP_HASH_SALT=
# The render_jobs ledger + JWT verification reuse VITE_SUPABASE_URL/VITE_SUPABASE_ANON_KEY and
# SUPABASE_SERVICE_ROLE_KEY above (without the service key, jobs live in process memory).
