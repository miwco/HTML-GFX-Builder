# Copy this file to .env (which is gitignored) and fill in what you use.
# Everything can also be set in the app: New project → Describe it → AI settings.

# Your Anthropic API key (https://console.anthropic.com) — used directly from your
# browser, sent only to Anthropic. Never commit a real key.
VITE_ANTHROPIC_API_KEY=

# Model for generation (default: claude-sonnet-5).
VITE_AI_MODEL=

# Hosted mode: a backend gateway URL that holds the real key server-side.
# When set, the app POSTs to $VITE_AI_PROXY_URL/messages and sends no key of its own.
VITE_AI_PROXY_URL=

# ── Supabase backend (Era 5) — all OPTIONAL. Leave blank to run in pure offline mode ──
# (no login, no cloud sync, exports unchanged — exactly the self-hostable offline tool).
# The anon key is PUBLIC (Row Level Security is the real boundary) so it is safe to ship in the
# client bundle. NEVER put the service_role key here or in any VITE_-prefixed var — those are
# bundled into the browser. Server secrets belong in the private deployment's secret store.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Hosted closed beta: set to "true" to force login before the app is usable. Leave blank/false for
# self-hosted or open instances (they run with no auth, like the offline tool).
VITE_REQUIRE_AUTH=
